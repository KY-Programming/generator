<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
      <DocumentationFile>bin\Release\EdgeCases.xml</DocumentationFile>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
      <DocumentationFile>bin\Debug\EdgeCases.xml</DocumentationFile>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="KY.Generator" Version="10.0.0-preview.40" />
        <PackageReference Include="KY.Generator.Angular" Version="10.0.0-preview.40" />
        <PackageReference Include="KY.Generator.AspDotNet" Version="10.0.0-preview.40" />
        <PackageReference Include="KY.Generator.Reflection" Version="10.0.0-preview.40" />
    </ItemGroup>

</Project>
